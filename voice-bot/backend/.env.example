# Google API Key for Gemini Live API
GOOGLE_API_KEY=your_google_api_key_here

# WhatsApp Provider (twilio or meta)
WHATSAPP_PROVIDER=twilio  # Change to "meta" to use Meta WhatsApp Cloud API

# Twilio Credentials (used when WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890  # Your Twilio WhatsApp enabled number (must be WhatsApp enabled)

# Meta WhatsApp Cloud API Credentials (used when WHATSAPP_PROVIDER=meta)
META_WHATSAPP_ACCESS_TOKEN=your_meta_access_token_here  # Long-lived page access token
META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id  # Your WhatsApp phone number ID
META_WHATSAPP_PHONE_NUMBER=+1234567890  # Your WhatsApp number

# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=VOCO_RealEstate

# Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# External URL for Twilio callbacks (e.g. ngrok URL)
# This MUST be set for Twilio to reach your server
EXTERNAL_URL=https://your-ngrok-url.ngrok-free.dev

# Outbound calls concurrency (how many calls to start in parallel)
# Increase if you need higher throughput; be mindful of Twilio limits.
MAX_CONCURRENT_CALLS=5

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# API Key for endpoint authentication (leave empty to disable auth)
API_KEY=

# Gemini Live API Settings
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Kore
GEMINI_THINKING=none

# System Prompt (optional - defaults to built-in real estate assistant prompt)
# SYSTEM_PROMPT=Your custom system prompt here

# Zoho CRM Credentials
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token_here
ZOHO_ORG_DOMAIN=https://www.zohoapis.in  # Use .com or .eu as per your region

MAX_APPOINTMENTS_PER_DAY=5

# System Prompt (optional - defaults to built-in real estate assistant prompt)
# SYSTEM_PROMPT=Your custom system prompt here